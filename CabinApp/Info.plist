<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>

    <!-- MARK: - App identity -->
    <key>CFBundleDisplayName</key>
    <string>Cabin</string>
    <key>CFBundleIdentifier</key>
    <string>$(PRODUCT_BUNDLE_IDENTIFIER)</string>
    <key>CFBundleVersion</key>
    <string>1</string>
    <key>CFBundleShortVersionString</key>
    <string>0.1.0</string>
    <key>CFBundlePackageType</key>
    <string>APPL</string>
    <key>CFBundleExecutable</key>
    <string>$(EXECUTABLE_NAME)</string>
    <key>CFBundleDevelopmentRegion</key>
    <string>en</string>
    <key>CFBundleInfoDictionaryVersion</key>
    <string>6.0</string>

    <!-- MARK: - Supported platforms -->
    <!-- iPad: landscape primary, portrait supported -->
    <key>UISupportedInterfaceOrientations~ipad</key>
    <array>
        <string>UIInterfaceOrientationLandscapeLeft</string>
        <string>UIInterfaceOrientationLandscapeRight</string>
        <string>UIInterfaceOrientationPortrait</string>
    </array>
    <key>UISupportedInterfaceOrientations~mac</key>
    <array>
        <string>UIInterfaceOrientationLandscapeLeft</string>
        <string>UIInterfaceOrientationLandscapeRight</string>
    </array>
    <key>UISupportedInterfaceOrientations</key>
    <array>
        <string>UIInterfaceOrientationLandscapeLeft</string>
        <string>UIInterfaceOrientationLandscapeRight</string>
    </array>

    <!-- MARK: - iPad Multitasking (Split View + Slide Over + PiP) -->
    <key>UIRequiresFullScreen</key>
    <false/>

    <!-- MARK: - Background Modes -->
    <key>UIBackgroundModes</key>
    <array>
        <string>audio</string>
        <string>processing</string>
    </array>

    <!-- MARK: - Privacy Usage Strings -->
    <key>NSMotionUsageDescription</key>
    <string>Cabin uses the gyroscope to let you look around the aircraft cabin by tilting your iPad.</string>

    <key>NSMicrophoneUsageDescription</key>
    <string>Cabin does not use the microphone. This key satisfies App Store requirements for apps with audio frameworks linked.</string>

    <!-- MARK: - Scene configuration -->
    <key>UIApplicationSceneManifest</key>
    <dict>
        <key>UIApplicationSupportsMultipleScenes</key>
        <true/>
        <key>UISceneConfigurations</key>
        <dict>
            <key>UIWindowSceneSessionRoleApplication</key>
            <array>
                <dict>
                    <key>UISceneConfigurationName</key>
                    <string>Default Configuration</string>
                    <key>UISceneDelegateClassName</key>
                    <string>$(PRODUCT_MODULE_NAME).SceneDelegate</string>
                </dict>
            </array>
        </dict>
    </dict>

    <!-- MARK: - Status bar -->
    <key>UIStatusBarHidden</key>
    <true/>
    <key>UIViewControllerBasedStatusBarAppearance</key>
    <false/>

    <!-- MARK: - ProMotion / high frame rate -->
    <key>CADisableMinimumFrameDurationOnPhone</key>
    <true/>

    <!-- MARK: - Metal / GPU -->
    <key>MetalCaptureEnabled</key>
    <false/>
    <key>MTLDefaultGPUPreference</key>
    <string>HighPower</string>

    <!-- MARK: - Launch screen -->
    <key>UILaunchStoryboardName</key>
    <string>LaunchScreen</string>

    <!-- MARK: - App Transport Security -->
    <key>NSAppTransportSecurity</key>
    <dict>
        <key>NSAllowsArbitraryLoads</key>
        <false/>
    </dict>

    <!-- MARK: - Background task scheduler -->
    <key>BGTaskSchedulerPermittedIdentifiers</key>
    <array>
        <string>com.cabin.sessiontimer</string>
    </array>

    <!-- macOS 26 / Xcode 26.4: Liquid Glass opt-in for UIKit shimmer on iPad -->
    <!-- SwiftUI uses it automatically; this key enables it for any UIKit overlays. -->
    <key>UIUserInterfaceStyle</key>
    <string>Automatic</string>

</dict>
</plist>
